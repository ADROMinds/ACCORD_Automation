      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>edge_Task_ExtractEmail-Gateway_JoinCLa4Ga</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_Join" name="Join">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:incoming>edge_Task_ExtractEmail-Gateway_JoinCLa4Ga</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_ClassificationAgent" name="Classification Agent">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartAgentJob" version="v2" />
          <uipath:context>
            <uipath:input name="name" type="string" value="=bindings.bVRl217O7" />
            <uipath:input name="folderPath" type="string" value="=bindings.bpznOcdeT" />
            <uipath:input name="_label" type="string" value="EmailAgent" />
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"email_payload":{"type":"object"},"confidence_threshold":{"type":"number"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"email_payload":{"subject":"=vars.outSubject","body":"=vars.outBody","sender":"=vars.outSender","received_at":"=vars.outReceivedAt","attachment_names":"=vars.outAttachementList","message_id":"=vars.outMessageId"},"confidence_threshold":0.7}]]></uipath:input>
          <uipath:output name="Error" type="jsonSchema" source="=Error" var="error2" />
          <uipath:output name="intent" type="string" source="=intent" var="intent" />
          <uipath:output name="summary" type="string" source="=summary" var="summary" />
