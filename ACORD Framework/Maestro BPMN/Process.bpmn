    <bpmn:sequenceFlow id="Flow_12" sourceRef="Event_WaitReply" targetRef="Gateway_Join" />
    <bpmn:sequenceFlow id="edge_Task_ExtractEmail-Gateway_JoinCLa4Ga" sourceRef="Task_ExtractEmail" targetRef="Gateway_Join" />
    <bpmn:sequenceFlow id="edge_Gateway_ConfidenceCheck-Task_IXPExtractionJvev65" sourceRef="Gateway_ConfidenceCheck" targetRef="Task_IXPExtraction">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=vars.confidence &gt;= 0.7</bpmn:conditionExpression>
