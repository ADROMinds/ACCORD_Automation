    <bpmn:serviceTask id="Task_ExtractEmail" name="Invoke Ingestion Flow">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartJob" version="v2" />
          <uipath:context>
            <uipath:input name="name" type="string" value="=bindings.bG3EzOJsr" />
            <uipath:input name="folderPath" type="string" value="=bindings.bP75LbOnv" />
