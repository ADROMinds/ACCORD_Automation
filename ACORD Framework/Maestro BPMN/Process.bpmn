            <uipath:input name="_label" type="string" value="ExtractionAgent" />
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"attachments":{"type":"array"},"mock_mode":{"type":"boolean"}},"required":["attachments"]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"attachments":[{"ID":"=vars.outMessageId","FullName":"=vars.outAttachementList[0]","MimeType":"application/JSON"}],"mock_mode":null}]]></uipath:input>
          <uipath:output name="Error" type="jsonSchema" source="=Error" var="error4" />
          <uipath:output name="filtering_results" type="jsonSchema" subType="object" source="=filtering_results" var="filteringResults" />
          <uipath:output name="extraction_results" type="jsonSchema" subType="object" source="=extraction_results" var="extractionResults" />
          <uipath:output name="summary" type="string" source="=summary" var="summary2" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>edge_Gateway_ConfidenceCheck-Task_IXPExtractionJvev65</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_ProcessingComplete" name="Processing Complete">
      <bpmn:incoming>Flow_9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_EmailArrives" targetRef="Task_ExtractEmail" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Gateway_Join" targetRef="Task_ClassificationAgent" />
    <bpmn:sequenceFlow id="Flow_6_No" sourceRef="Gateway_ConfidenceCheck" targetRef="Task_HITL">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=vars.confidence&lt;0.7</bpmn:conditionExpression>
