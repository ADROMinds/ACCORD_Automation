        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>edge_Task_ClassificationAgent-Gateway_ConfidenceChecksIZ4yf</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_ConfidenceCheck" name="Confidence &#62;= 70%?">
      <bpmn:incoming>edge_Task_ClassificationAgent-Gateway_ConfidenceChecksIZ4yf</bpmn:incoming>
      <bpmn:outgoing>Flow_6_No</bpmn:outgoing>
