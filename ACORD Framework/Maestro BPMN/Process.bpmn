      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:intermediateThrowEvent id="Event_SendAck" name="Send Ack to Broker">
      <bpmn:extensionElements>
        <uipath:event version="v1">
          <uipath:type value="Maestro.SendMessageEvent" version="v1" />
          <uipath:context>
            <uipath:input name="name" value="BrokerAcknowledgement" />
            <uipath:input name="_label" value="Send Acknowledgement" />
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"Reference":{"type":"string","title":"Reference"},"SpecificContent":{"type":"object","title":"Item information"},"TimeToLive":{"type":"duration","title":"Time to live"}},"required":["Reference","name"]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="ItemData" type="json" target="body"><![CDATA[{"Reference":"HITL_ACK","SpecificContent":"={\"emailSubject\":varsEmailSubject,\"brokerAction\":\"Please review and reply\"}","TimeToLive":"PT24H"}]]></uipath:input>
          <uipath:output name="response" type="Maestro.SendMessageEvent" var="Var_SendAckResponse" />
        </uipath:event>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:intermediateThrowEvent>
    <bpmn:intermediateCatchEvent id="Event_WaitReply" name="Wait Broker Reply">
      <bpmn:extensionElements>
        <uipath:event version="v1">
          <uipath:type value="Maestro.ReceiveMessageEvent" version="v1" />
          <uipath:context>
            <uipath:input name="name" value="BrokerReply" />
            <uipath:input name="_label" value="Receive Broker Reply" />
          </uipath:context>
          <uipath:input name="Reference" type="string" value="BROKER_REPLY" target="body" />
          <uipath:output name="response" type="Maestro.ReceiveMessageEvent" var="Var_ReceiveReplyResponse" />
        </uipath:event>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
      <bpmn:messageEventDefinition />
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="Task_IXPExtraction" name="IXP Extraction Agent">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartAgentJob" version="v2" />
